VITE_MAPBOX_TOKEN=
VITE_LOCATIONIQ_KEY=

# Optional development flags. Leave false/unset for the presentation UI.
# Show the developer diagnostics panel (storage mode, service booleans, session).
VITE_SHOW_DIAGNOSTICS=false
# Enable the synthetic A* algorithm demo and its mode switch.
VITE_ENABLE_SYNTHETIC_DEMO=false

# Optional: annotated obstacle-detection MJPEG stream served by the Raspberry Pi
# (vision_modal headless mode). Loaded directly from the Pi, behind a toggle.
# Example: http://192.168.1.42:8000
VITE_VISION_STREAM_URL=
