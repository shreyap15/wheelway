# Google Maps Platform API key (Elevation, Places)
GOOGLE_MAPS_API_KEY=

# Mapbox access token (Directions walking geometry)
MAPBOX_ACCESS_TOKEN=

# ASI:One API key for LLM-powered direction synthesis
ASI_ONE_API_KEY=

# Cloud deploy / Agentverse (Render sets RENDER_EXTERNAL_URL automatically)
# AGENT_PUBLIC_URL=https://your-service.onrender.com
# AGENTVERSE_NAME=accessroute-orchestrator
# USE_MAILBOX=false

# Optional demo grade limits for steep campus testing (defaults: 25.0 / 25.0)
# DEMO_MAX_INCLINE_GRADE=25.0
# DEMO_MAX_DECLINE_GRADE=25.0
