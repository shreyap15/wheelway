# WheelWay vision bridge configuration (Raspberry Pi / laptop).
# Copy to hardware/.env. Process environment overrides these. Never commit a real .env.

# Backend reachable from the Pi. Do NOT use localhost on the Pi -- use the
# laptop/server LAN or Tailscale IP that the Pi can actually reach.
WHEELWAY_BACKEND_URL=http://192.168.1.25:5000

# Optional bearer token sent as Authorization header (never logged).
WHEELWAY_DEVICE_TOKEN=

WHEELWAY_DEVICE_ID=wheelway-pi-01
WHEELWAY_PUBLISH_ENABLED=true
WHEELWAY_PUBLISH_TIMEOUT_SECONDS=2
WHEELWAY_HEARTBEAT_SECONDS=5

# TTC (seconds) thresholds for warning/critical promotion of steering commands.
WHEELWAY_WARNING_TTC_SECONDS=3
WHEELWAY_CRITICAL_TTC_SECONDS=1.5

# Bounded publish queue (drops stale non-critical events first; keeps newest critical).
WHEELWAY_QUEUE_SIZE=20

# Reported in observations for provenance (pin to the upstream commit).
WHEELWAY_PIPELINE_VERSION=vision-modal-7b9d823

# OpenAI scene reasoning is OPTIONAL and off the collision hot path. The key stays
# on the Pi; it is NEVER sent to the WheelWay backend/frontend. Omit / use --no-llm
# to run without it. The default Pi demo works without OpenAI.
# OPENAI_API_KEY=
