# === Backend (FastAPI / AccessTwin API) ===
# Read by app/core/database.py. Copy to .env and fill in.

# Async Postgres connection string
DATABASE_URL=postgresql+asyncpg://postgres:postgrespassword@localhost:5432/accesstwin

# Deepgram text-to-speech for voice alerts (server-side only; never sent to the
# browser). If unset, POST /speak returns 503 and voice alerts are unavailable.
DEEPGRAM_API_KEY=
